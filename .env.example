# Supabase — get these from your project settings at https://supabase.com/dashboard
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# App URL — used for OAuth redirect callbacks
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Creem — payment processing
CREEM_API_KEY=creem_your-api-key-here
CREEM_WEBHOOK_SECRET=whsec_your-webhook-secret-here
CREEM_PRODUCT_PRO_MONTHLY=prod_xxx
CREEM_PRODUCT_PRO_YEARLY=prod_xxx
CREEM_PRODUCT_BUSINESS_MONTHLY=prod_xxx
CREEM_PRODUCT_BUSINESS_YEARLY=prod_xxx
